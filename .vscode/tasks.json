{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install",
      "type": "shell",
      "command": "npm install && npm rebuild better-sqlite3",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "fix: kill node + rebuild sqlite + start",
      "type": "shell",
      "command": "taskkill /F /IM node.exe 2>$null; Start-Sleep -Seconds 2; Remove-Item -Recurse -Force node_modules/better-sqlite3/build -ErrorAction SilentlyContinue; npm rebuild better-sqlite3; npm start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "npm: start server",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "dependsOn": []
    }
  ]
}
