SESSION_SECRET=replace-with-long-random-secret

# Razorpay — online advance payment (https://dashboard.razorpay.com/app/keys)
# IMPORTANT: Use TEST keys (rzp_test_) on localhost — LIVE keys block 127.0.0.1
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Webhook secret (Dashboard → Webhooks → payment.captured) — for live site
RAZORPAY_WEBHOOK_SECRET=
# Advance % charged at order time (default 50)
PAYMENT_ADVANCE_PERCENT=50

# Gmail / Google login — create at https://console.cloud.google.com/apis/credentials
# OAuth client → Web application → Authorized redirect URI must match exactly:
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/auth/google/callback

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1:3000/auth/github/callback

# Microsoft OAuth — Azure App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://127.0.0.1:3000/auth/microsoft/callback

BASE_URL=http://127.0.0.1:3000

# AI chat — smart replies (recommended). Key: https://platform.openai.com/api-keys
# Compatible APIs (Groq, etc.): set OPENAI_API_BASE e.g. https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1

# PostgreSQL (required) — use DATABASE_URL or individual vars
DATABASE_URL=postgres://postgres:yourpassword@127.0.0.1:5432/web_project
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=yourpassword
# PGDATABASE=web_project
# PGSSL=false
DB_POOL_LIMIT=10

# Admin dashboard — comma-separated emails (must match login email on site)
ADMIN_EMAILS=your@email.com

# Google reCAPTCHA v2 — https://www.google.com/recaptcha/admin (Checkbox "I'm not a robot")
# Add your Render domain: techwithaman-website-2026.onrender.com
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Optional dev only: visit /admin/connect?secret=... once (remove on public deploy)
# ADMIN_BOOTSTRAP_SECRET=
