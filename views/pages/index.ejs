<%- include("../partials/head", { page }) %>
<%- include("../partials/navbar", { navItems, brand, page }) %>

  <main>
    <section class="hero" id="home">
      <div class="overlay"></div>
      <div class="container hero-content">
        <h1>Welcome to TechWithAman</h1>
        <p class="hero-rotate">
          <span class="hero-rotate-label">I can help you with </span>
          <span
            id="typewriter"
            class="typewriter"
            data-words='["Web Development","App Development","Logo Design","Student Projects","Project Mentoring"]'
            data-type-speed="60"
            data-delete-speed="60"
            data-pause="1100"
          ></span>
        </p>
        <p>
          Client website, app development, logo design aur student projects ke liye trusted place.
          Professional design, fast delivery aur proper guidance.
        </p>
        <div class="hero-actions">
          <a class="btn" href="/pricing">View Pricing</a>
          <a class="btn btn-outline" href="/services">View Services</a>
        </div>
        <div class="hero-stats">
          <div>
            <h3>100+</h3>
            <p>Projects</p>
          </div>
          <div>
            <h3>500K+</h3>
            <p>Clients</p>
          </div>
          <div>
            <h3>5.0</h3>
            <p>Rating</p>
          </div>
        </div>
      </div>
    </section>

    <section id="home-showcase" class="section home-showcase-section" aria-label="Featured work carousel">
      <div class="container">
        <p class="small-heading">Portfolio</p>
        <h2>Actions speak louder than words</h2>
        <div class="home-showcase-wrap">
          <button type="button" class="home-showcase-arrow home-showcase-prev" aria-label="Previous project">‹</button>
          <div class="home-showcase-viewport">
            <div id="home-showcase-track" class="home-showcase-slider"></div>
          </div>
          <button type="button" class="home-showcase-arrow home-showcase-next" aria-label="Next project">›</button>
        </div>
        <div id="home-showcase-dots" class="home-showcase-dots" role="tablist" aria-label="Project slides"></div>
      </div>
    </section>

    <section class="section" id="pricing">
      <div class="container">
        <p class="small-heading">Pricing</p>
        <h2>Choose a Plan That Fits You</h2>
        <div class="home-showcase-wrap home-pricing-wrap">
          <button type="button" class="home-showcase-arrow home-pricing-prev" aria-label="Previous plan">‹</button>
          <div class="home-showcase-viewport home-pricing-viewport">
            <div id="home-pricing-track" class="home-showcase-slider"></div>
          </div>
          <button type="button" class="home-showcase-arrow home-pricing-next" aria-label="Next plan">›</button>
        </div>
        <div id="home-pricing-dots" class="home-showcase-dots" role="tablist" aria-label="Pricing slides"></div>
      </div>
    </section>

    <section class="section dark" id="services">
      <div class="container">
        <h2>Client Services</h2>
        <div class="grid two">
          <article class="card home-card" data-home-id="website-dev">
            <div class="home-card__media">
              <img src="https://images.unsplash.com/photo-1547658719-da2b51169166?auto=format&fit=crop&w=900&q=80" width="900" height="563" loading="lazy" decoding="async" alt="Website development">
            </div>
            <div class="home-card__body">
              <h3>Website Development</h3>
              <p>Business, portfolio, landing and e-commerce website.</p>
              <span class="home-card__link">View details →</span>
            </div>
          </article>
          <article class="card home-card" data-home-id="app-dev">
            <div class="home-card__media">
              <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?auto=format&fit=crop&w=900&q=80" width="900" height="563" loading="lazy" decoding="async" alt="App development">
            </div>
            <div class="home-card__body">
              <h3>App Development</h3>
              <p>Web app and Android app with clean and modern UI.</p>
              <span class="home-card__link">View details →</span>
            </div>
          </article>
          <article class="card home-card" data-home-id="logo-design">
            <div class="home-card__media">
              <img src="https://images.unsplash.com/photo-1558655146-d09347e92766?auto=format&fit=crop&w=900&q=80" width="900" height="563" loading="lazy" decoding="async" alt="Logo design">
            </div>
            <div class="home-card__body">
              <h3>Logo Design</h3>
              <p>Professional logo and branding kit creation.</p>
              <span class="home-card__link">View details →</span>
            </div>
          </article>
          <article class="card home-card" data-home-id="student-projects">
            <div class="home-card__media">
              <img src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?auto=format&fit=crop&w=900&q=80" width="900" height="563" loading="lazy" decoding="async" alt="Student projects">
            </div>
            <div class="home-card__body">
              <h3>Student Projects</h3>
              <p>Final year projects with report and presentation support.</p>
              <span class="home-card__link">View details →</span>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="testimonials">
      <div class="container">
        <h2>Testimonials</h2>
        <div class="grid two">
          <article class="card quote">
            <p>"Design quality top-class thi. Website exactly meri demand jaisi bani."</p>
            <h4>Mohit Kumar</h4>
            <span>Web Developer</span>
          </article>
          <article class="card quote">
            <p>"Student project aur viva prep dono clear and easy way me mila."</p>
            <h4>Rakesh Shetty</h4>
            <span>Engineering Student</span>
          </article>
        </div>
      </div>
    </section>

    <section class="section cta" id="contact">
      <div class="container cta-box">
        <h2>Start Your Coding Journey</h2>
        <p>Learn coding step-by-step with #TechWithAman</p>
        <a class="btn" href="/contact">Contact Now</a>
      </div>
    </section>
  </main>

  <div id="home-detail-modal" class="home-detail-modal" hidden role="dialog" aria-modal="true" aria-labelledby="home-detail-title">
    <div class="home-detail-backdrop"></div>
    <div class="home-detail-dialog">
      <button type="button" class="home-detail-close" aria-label="Close details">×</button>
      <div id="home-detail-body"></div>
    </div>
  </div>

<%- include("../partials/footer", { brand, year }) %>
<%- include("../partials/scripts") %>
