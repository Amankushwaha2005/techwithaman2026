<%# =============================================================================
   ORDER SUCCESS PAGE
   URL: /order/success
   File: views/pages/order-success.ejs
   Payment confirmation summary
   ============================================================================= %>
<%- include("../partials/head", { page }) %>
<%- include("../partials/navbar", { navItems, brand, page }) %>

  <main>
    <section class="section order-success-section">
      <div class="container">
        <article class="card order-success-card">
          <% if (order && order.status === 'paid') { %>
            <span class="chip">Payment received</span>
            <h1>Thank you, <%= order.name %>!</h1>
            <p>Your advance payment is confirmed. We will contact you shortly to start your project.</p>
            <dl class="order-summary-list">
              <div><dt>Order ID</dt><dd><code><%= order.public_id %></code></dd></div>
              <div><dt>Service</dt><dd><%= order.service %></dd></div>
              <div><dt>Package</dt><dd><%= order.plan %></dd></div>
              <div><dt>Paid (advance)</dt><dd>₹<%= order.amount_inr.toLocaleString("en-IN") %></dd></div>
              <div><dt>Package total</dt><dd>₹<%= order.total_inr.toLocaleString("en-IN") %></dd></div>
              <% if (receipt) { %>
              <div><dt>Payment date</dt><dd><%= receipt.paymentDate %></dd></div>
              <div><dt>Gateway</dt><dd><%= receipt.gateway %></dd></div>
              <% if (receipt.paymentId && receipt.paymentId !== '—') { %>
              <div><dt>Payment ID</dt><dd><code><%= receipt.paymentId %></code></dd></div>
              <% } %>
              <% } %>
            </dl>
          <% } else { %>
            <h1>Order not found</h1>
            <p>If you just paid, wait a moment and refresh — or contact us on WhatsApp with your payment screenshot.</p>
          <% } %>
          <div class="order-success-actions">
            <% if (order && order.status === 'paid') { %>
            <a
              class="btn"
              href="/order/receipt?id=<%= encodeURIComponent(order.public_id) %>&print=1"
              target="_blank"
              rel="noopener noreferrer"
            >Download receipt</a>
            <a
              class="btn btn-outline"
              href="/order/receipt?id=<%= encodeURIComponent(order.public_id) %>"
              target="_blank"
              rel="noopener noreferrer"
            >View receipt</a>
            <% } %>
            <a class="btn btn-outline" href="/">Back to home</a>
            <a class="btn btn-outline" href="/pricing">View pricing</a>
          </div>
        </article>
      </div>
    </section>
  </main>

<%- include("../partials/footer", { brand, year }) %>
<%- include("../partials/scripts") %>
