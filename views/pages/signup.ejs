<%# =============================================================================
   SIGNUP PAGE
   URL: /signup
   File: views/pages/signup.ejs
   Social signup, email signup, reCAPTCHA
   ============================================================================= %>
<%- include("../partials/head", { page }) %>
  <main class="login-page">
    <section class="login-shell" aria-label="Signup card">
      <article class="login-card">
        <div class="login-left">
          <h1>Welcome!</h1>
          <p class="login-subtitle">Create your account</p>
          <p class="login-helper">Sign up with Gmail in one click or use email below</p>

          <% if (authError) { %>
            <p class="auth-error" role="alert"><%= authError %></p>
          <% } %>

          <%- include("../partials/google-auth", { googleAuthFrom: 'signup' }) %>

          <div class="login-divider"><span>Or</span></div>

          <details class="login-email-block" open>
            <summary>Signup via Email</summary>
            <form class="auth-form" action="/auth/signup" method="post">
              <input class="auth-input" type="text" name="name" placeholder="Full Name" required>
              <input class="auth-input" type="email" name="email" placeholder="Email" required>
              <input class="auth-input" type="password" name="password" placeholder="Password" required>
              <%- include("../partials/recaptcha-widget") %>
              <button class="btn auth-submit" type="submit">Create Account</button>
            </form>
          </details>

          <p class="auth-switch-link">Already have an account? <a href="/login">Login</a></p>
        </div>

        <div class="login-right" aria-hidden="true">
          <img src="https://images.unsplash.com/photo-1510915228340-29c85a43dcfe?auto=format&fit=crop&w=1400&q=80" alt="Programmer working with multiple screens" loading="lazy">
        </div>
      </article>
    </section>
  </main>

<%- include("../partials/footer", { brand, year }) %>
<%- include("../partials/scripts") %>
