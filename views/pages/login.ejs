<%# =============================================================================
   LOGIN PAGE
   URL: /login
   File: views/pages/login.ejs
   Social login, email login, reCAPTCHA
   ============================================================================= %>
<%- include("../partials/head", { page }) %>
  <main class="login-page">
    <section class="login-shell" aria-label="Login card">
      <article class="login-card">
        <div class="login-left">
          <h1>Welcome to TechWithAman</h1>
          <p class="login-subtitle">Login to your account</p>
          <p class="login-helper">Sign in with Google, GitHub, Microsoft, or email below</p>

          <% if (authError) { %>
            <p class="auth-error" role="alert"><%= authError %></p>
          <% } %>

          <%- include("../partials/social-auth", { googleAuthFrom: 'login' }) %>

          <div class="login-divider"><span>Or</span></div>

          <details class="login-email-block" open>
            <summary>Continue via Email</summary>
            <form class="auth-form" action="/auth/login" method="post">
              <% if (typeof loginNext !== 'undefined' && loginNext) { %>
                <input type="hidden" name="next" value="<%= loginNext %>">
              <% } %>
              <input class="auth-input" type="email" name="email" placeholder="Email" required>
              <input class="auth-input" type="password" name="password" placeholder="Password" required>
              <%- include("../partials/recaptcha-widget") %>
              <button class="btn auth-submit" type="submit">Login</button>
            </form>
          </details>

          <p class="auth-switch-link">New here? <a href="/signup">Create an account</a></p>
        </div>

        <div class="login-right" aria-hidden="true">
          <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=1400&q=80" alt="Developer coding on laptop" loading="lazy">
        </div>
      </article>
    </section>
  </main>

<%- include("../partials/footer", { year, brand }) %>
<%- include("../partials/scripts") %>
